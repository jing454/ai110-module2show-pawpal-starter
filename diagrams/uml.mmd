classDiagram
    %% PawPal+ — pet care planning assistant
    %% Four core classes: Owner, Pet, Task, Scheduler

    class Owner {
        +str name
        +list~Pet~ pets
        +Scheduler scheduler
        +add_pet(pet Pet) void
        +remove_pet(pet Pet) void
        +block_time(start datetime, end datetime, reason str) void
        +list_tasks() list~Task~
        +mark_task_complete(task Task) Task
        +tasks_for_pet(pet_name str) list~Task~
        +task_by_status(done bool) list~Task~
        +filter_tasks(pet_name str, done bool) list~Task~
        +overdue_tasks() list~Task~
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task Task) void
        +complete_task(task Task) Task
        +delete_task(task Task) void
        +edit_task(updated Task) void
        +progress() float
    }

    class Task {
        +int id
        +str title
        +int duration_minutes
        +str priority
        +str frequency
        +int weekday
        +bool done
        +datetime scheduled_at
        +datetime deadline
        +is_due_on(day date) bool
        +mark_done() void
        +mark_undone() void
        +is_overdue() bool
        +next_occurrence(completed_on date) Task
    }

    class Scheduler {
        +list~Task~ tasks
        +list~dict~ blocked_times
        +add_blocked_time(start datetime, end datetime, reason str) void
        +build_schedule(owner Owner, day date) list~Task~
        +order_by_priority(tasks list) list~Task~
        +sort_by_time(tasks list) list~Task~
        +fits_in_window(task Task, start_time datetime) bool
        +find_conflicts(tasks list) list~tuple~
        +conflict_warning(tasks list) str
        +explain() str
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Owner "1" --> "1" Scheduler : holds / delegates to
    Scheduler "1" --> "*" Task : schedules
    Scheduler ..> Owner : reads tasks from
    Task ..> Task : spawns next_occurrence
